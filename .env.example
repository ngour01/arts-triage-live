# ARTs v1.0.0 — Environment Variables
# Copy this file to .env and adjust if needed.
#   cp .env.example .env
#
# Default database matches `docker compose` local Postgres (db service) or a local install.

# ── PostgreSQL ────────────────────────────────────────────────────
# Full DSN for the FastAPI backend (pydantic-settings).
# Local (Docker Compose): postgres / password, database art_triage, host localhost when port-forwarded
DATABASE_URL=postgresql://postgres:password@localhost:5432/art_triage

# Individual components (reference for local Postgres / docker-compose overrides).
POSTGRES_DB=art_triage
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Backend Tuning ────────────────────────────────────────────────
DB_POOL_MIN=1
DB_POOL_MAX=20
REDIS_CACHE_TTL=300
BATCH_MAX_SIZE=500

# ── API auth (optional; required for POST/PUT/PATCH writes when set) ─
ART_API_KEY=

# ── Frontend ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
# Dev only: sends X-API-Key from the browser when ART_API_KEY is enabled server-side
NEXT_PUBLIC_ART_API_KEY=
